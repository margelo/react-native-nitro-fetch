{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": [
    "nitrotextdecoder"
  ],
  "ios": {
    "iosModuleName": "NitroTextDecoder"
  },
  "android": {
    "androidNamespace": [
      "nitrotextdecoder"
    ],
    "androidCxxLibName": "NitroTextDecoder"
  },
  "autolinking": {    
    "NitroTextEncoding": {
      "all": {
        "language": "c++",
        "implementationClassName": "HybridTextEncoding"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
